rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // 1. Users Collection
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt', 'updatedAt'])
        && data.email is string && data.email.size() <= 256
        && data.createdAt == request.time
        && data.updatedAt == request.time
        && data.get('displayName', '') is string
        && data.get('displayName', '').size() <= 128
        && (!data.keys().hasAny(['subscriptionStatus', 'stripeCustomerId'])); // Protect system fields
    }

    function isValidUserUpdate(data) {
      return data.get('displayName', '') is string
        && data.get('displayName', '').size() <= 128
        && data.updatedAt == request.time;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
      // No allow list for users because it's not needed by client usually, but if needed, restrict properly.

      allow create: if isSignedIn() 
        && request.auth.uid == userId 
        && isValidId(userId)
        && isValidUser(incoming());

      allow update: if isSignedIn()
        && request.auth.uid == userId
        && isValidId(userId)
        && isValidUserUpdate(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'updatedAt']);
    }

    // 2. Documents Collection
    function isValidDocumentCreate(data) {
      return data.keys().hasAll(['userId', 'title', 'textContent', 'createdAt', 'updatedAt'])
        && data.keys().size() <= 5
        && data.userId == request.auth.uid
        && data.title is string && data.title.size() <= 256
        && data.textContent is string && data.textContent.size() <= 1048576 // 1MB text limit
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidDocumentUpdate(data) {
      return data.title is string && data.title.size() <= 256
        && data.textContent is string && data.textContent.size() <= 1048576
        && data.updatedAt == request.time
        && data.userId == request.auth.uid; // Keep the same owner
    }

    match /documents/{documentId} {
      allow get: if isSignedIn() 
        && isValidId(documentId) 
        && existing().userId == request.auth.uid;

      allow list: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn()
        && isValidId(documentId)
        && isValidDocumentCreate(incoming())
        && exists(/databases/$(database)/documents/users/$(incoming().userId));

      allow update: if isSignedIn()
        && isValidId(documentId)
        && existing().userId == request.auth.uid
        && isValidDocumentUpdate(incoming())
        && incoming().userId == existing().userId
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'textContent', 'updatedAt']);

      allow delete: if isSignedIn()
        && isValidId(documentId)
        && existing().userId == request.auth.uid;
    }
  }
}
